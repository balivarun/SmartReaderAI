# Example environment variables for backend local development
# Do NOT commit real credentials. Copy this file to `.env` and fill in values.

# Either supply DATABASE_URL in one of these accepted forms:
#  - postgres://user:password@host:port/dbname
#  - jdbc:postgresql://host:port/dbname
# If you provide a postgres:// URL the app will extract username/password and
# convert to a proper JDBC URL.
DATABASE_URL=postgres://smartreaderai_user:changeme@dpg-d8eqqd1o3t8c73foqo50-a.oregon-postgres.render.com:5432/smartreaderai

# Alternatively set these separately:
DATABASE_USER=smartreaderai_user
DATABASE_PASSWORD=changeme

# Optional: override Spring properties directly
# SPRING_DATASOURCE_URL=jdbc:postgresql://host:5432/smartreaderai
# SPRING_DATASOURCE_USERNAME=smartreaderai_user
# SPRING_DATASOURCE_PASSWORD=changeme
